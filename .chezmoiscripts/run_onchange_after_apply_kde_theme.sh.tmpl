#!/bin/bash

# layout hash: {{ include "dot_local/share/plasma/look-and-feel/Main/contents/layouts/org.kde.plasma.desktop-layout.js.tmpl" | sha256sum }}
# defaults hash: {{ include "dot_local/share/plasma/look-and-feel/Main/contents/private_defaults" | sha256sum }}
